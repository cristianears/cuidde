# .env.example — copie para .env.local e preencha os valores
# NUNCA commitar o .env.local

# ─── Supabase ────────────────────────────────────────────────────────────────
# Dashboard > Settings > API
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# ─── Stripe (frontend) ───────────────────────────────────────────────────────
# Dashboard > Developers > API Keys > Publishable key
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...

# ─── Secrets — APENAS em Supabase Edge Functions ─────────────────────────────
# Nunca expor estas variáveis no frontend (sem prefixo VITE_)

# Stripe Secret Key — Dashboard > Developers > API Keys > Secret key
STRIPE_SECRET_KEY=sk_live_...

# Stripe Webhook Secret — Dashboard > Developers > Webhooks > Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs — Dashboard > Products > (cada plano) > Price ID
STRIPE_PRICE_ID_MONTHLY=price_...
STRIPE_PRICE_ID_QUARTERLY=price_...
STRIPE_PRICE_ID_ANNUAL=price_...

# Supabase Service Role Key — Dashboard > Settings > API > service_role
SUPABASE_SERVICE_ROLE_KEY=eyJ...
GOOGLE_MAPS_API_KEY=sua_chave_aqui