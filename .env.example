# Copy this file to .env.local and fill in the values.
# Never commit .env.local.

# Frontend variables used by Vite / Cloudflare Pages
# Cloudflare Pages > Project > Settings > Environment variables

# Supabase public API config
# Supabase Dashboard > Project Settings > API
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# Google Maps Geocoding key used by the browser.
# Restrict this key to icuide.com.br, www.icuide.com.br, and localhost for development.
VITE_GMAPS_GEOCODE_KEY=sua_chave_aqui

# Stripe Price IDs used by the browser to request a checkout session.
# These are price IDs, not secret keys.
VITE_STRIPE_PRICE_MONTHLY=price_...
VITE_STRIPE_PRICE_QUARTERLY=price_...
VITE_STRIPE_PRICE_ANNUAL=price_...

# Optional if you later use Stripe.js directly in the frontend.
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Server-side secrets below belong only in Supabase Edge Functions.
# Do not add them to Cloudflare Pages and do not expose them with VITE_.

STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
GOOGLE_MAPS_API_KEY=sua_chave_aqui
